# PROBLEM 2 — Two sum  (CLASSIC interview question)
# Given a list of numbers and a target, return the INDICES (as a list of 2)
# of two numbers that add up to target. Assume exactly one answer exists.
# Example: two_sum([2, 7, 11, 15], 9) → [0, 1]     (because 2 + 7 = 9)
#          two_sum([3, 2, 4], 6)      → [1, 2]     (because 2 + 4 = 6)
# Hint: For each number x, you need (target - x). Store what you've seen
#       in a dict {value: index}. If the "need" is already in the dict, done!
# -----------------------------------------------------------------------------
def two_sum(nums, target):
    for idx,ele in enumerate(nums):
        gap= target-ele
        for i in range(idx+1, len(nums)):
            if (nums[i]==gap):
                return ([idx,i])
    return []   
