# Return True if two strings are anagrams (same letters, different order).
# Case sensitive. Ignore no whitespace. Length must match too.
# Example: are_anagrams("listen", "silent") → True
#          are_anagrams("hello", "world")   → False
#          are_anagrams("aab", "abb")       → False
# Hint: Two anagrams have the SAME letter counts. Count each, compare dicts.
# -----------------------------------------------------------------------------
def are_anagrams(s1, s2):
    # TODO
    mydict1={}
    mydict2= {}
    for ele1 in s1:
        if (ele1 in mydict1):
            mydict1[ele1]+=1
        else:
            mydict1[ele1]=1
    for ele2 in s2:
        if (ele2 in mydict2):
            mydict2[ele2]+=1
        else:
            mydict2[ele2]=1

    return mydict1 == mydict2 #dictionaries can compare themselves regardless of order

