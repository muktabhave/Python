# PROBLEM 3 — Word frequency top N
# Given a list of words and integer n, return the n most frequent words
# as a list, ordered by frequency (highest first).
# If two words tie, either order is fine.
# Example: top_n_words(["a", "b", "a", "c", "b", "a", "d"], 2) → ["a", "b"]
# Edge case: n greater than unique words → return all of them
# Hint: count first, then sort by count.
#       sorted(counts.items(), key=lambda pair: pair[1], reverse=True)
# -----------------------------------------------------------------------------
def top_n_words(words, n):
    # TODO
    mydict={}
    for ele in words:
        if(ele in mydict):
            mydict[ele]+=1
        else:
            mydict[ele]=1
    
    #sort dictionary based on its values
    op_dict= dict(sorted(mydict.items(), key= lambda item:item[1], reverse=True))
    
    counter=1
    new_list=[]
    for i in op_dict:
        if(counter<=n):
            new_list.append(i)
        counter+=1
    return new_list

